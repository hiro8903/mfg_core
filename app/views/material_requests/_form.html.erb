<%= form_with(model: material_request, class: "contents") do |form| %>
  <% if material_request.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-4 py-3 font-medium rounded-xl mt-3 border border-red-100 shadow-sm">
      <h2 class="text-sm font-bold"><%= material_request.errors.count %>件のエラーにより保存できませんでした:</h2>
      <ul class="mt-1 text-xs list-disc list-inside">
        <% material_request.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
    <div class="space-y-5">
      <div>
        <%= form.label :applicant_id, "申請者 (資材を必要としている人)", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1" %>
        <%= form.collection_select :applicant_id, User.all, :id, :name, { prompt: "申請者（担当者）を選択してください" }, class: "mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm bg-gray-50/50" %>
      </div>

      <div>
        <%= form.label :request_org_id, "依頼部門 (コストセンター)", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1" %>
        <%= form.collection_select :request_org_id, OrgUnit.all, :id, :name, { prompt: "部署を選択してください" }, class: "mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm bg-gray-50/50" %>
      </div>

      <div>
        <%= form.label :transaction_type, "取引区分", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1" %>
        <%= form.select :transaction_type, MaterialRequest.transaction_types.keys.map { |k| [t("activerecord.attributes.material_request.transaction_types.#{k}", default: k.humanize), k] }, {}, class: "mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm bg-gray-50/50" %>
      </div>
    </div>

    <div class="space-y-5">
      <div>
        <%= form.label :purpose, "使用目的", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1" %>
        <%= form.text_area :purpose, rows: 2, class: "mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm bg-gray-50/50", placeholder: "例：プロジェクトAの試作開発に使用" %>
      </div>

      <div>
        <%= form.label :reason, "理由・備考", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1" %>
        <%= form.text_area :reason, rows: 2, class: "mt-1 block w-full rounded-xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm bg-gray-50/50", placeholder: "例：在庫が枯渇したため" %>
      </div>
    </div>
  </div>

  <div class="mt-12 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-6 py-4 bg-gray-50/50 border-b border-gray-100 flex justify-between items-center">
      <h3 class="text-sm font-bold text-gray-900 tracking-tight">要求明細 (資材リスト)</h3>
    </div>
    
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50/30">
          <tr>
            <th class="px-6 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">品目（マスタまたは直接入力）</th>
            <th class="px-6 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">数量</th>
            <th class="px-6 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">単位</th>
            <th class="px-6 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">希望納期</th>
            <th class="px-6 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-50">
          <%= form.fields_for :material_request_lines do |line_form| %>
            <tr class="line-fields hover:bg-gray-50/50 transition-colors">
              <td class="px-6 py-5">
                <%= line_form.collection_select :item_id, Item.all, :id, :name, { prompt: "品目を選択（任意）" }, class: "block w-full rounded-lg border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm mb-2" %>
                <%= line_form.text_field :item_name_free_text, placeholder: "未登録品の場合はここに品名を入力", class: "block w-full rounded-lg border-gray-100 text-xs shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
              </td>
              <td class="px-6 py-5">
                <%= line_form.number_field :order_quantity, step: :any, class: "block w-24 rounded-lg border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "0.0" %>
              </td>
              <td class="px-6 py-5">
                <%= line_form.text_field :order_unit, placeholder: "個 / 式", class: "block w-20 rounded-lg border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
              </td>
              <td class="px-6 py-5">
                <%= line_form.date_field :required_date, class: "block w-full rounded-lg border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
              </td>
              <td class="px-6 py-5 text-right">
                <% if line_form.object.persisted? %>
                  <div class="flex items-center justify-end">
                    <%= line_form.check_box :_destroy, class: "rounded border-gray-300 text-red-600 focus:ring-red-500" %>
                    <%= line_form.label :_destroy, "削除", class: "ml-1.5 text-xs font-bold text-red-500" %>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-12 flex justify-end space-x-4 border-t border-gray-100 pt-8">
    <%= link_to "キャンセル", material_requests_path, class: "px-6 py-2.5 text-sm font-bold text-gray-500 bg-white border border-gray-200 rounded-xl shadow-sm hover:bg-gray-50 hover:text-gray-700 transition-all" %>
    <%= form.submit "資材要求を保存する", class: "px-8 py-2.5 text-sm font-bold text-white bg-indigo-600 border border-transparent rounded-xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 hover:shadow-indigo-300 transition-all cursor-pointer" %>
  </div>
<% end %>
