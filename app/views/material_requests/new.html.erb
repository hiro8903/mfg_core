<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="mb-8 flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <%= link_to material_requests_path, class: "p-2 rounded-lg bg-white border border-gray-200 text-gray-400 hover:text-indigo-600 hover:border-indigo-100 hover:bg-indigo-50/30 transition-all shadow-sm group" do %>
        <svg class="h-5 w-5 transform group-hover:-translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      <% end %>
      <h1 class="text-2xl font-bold text-gray-900 tracking-tight">新規資材要求の作成</h1>
    </div>
  </div>

  <div class="bg-white shadow-xl shadow-indigo-100/50 rounded-2xl p-8 border border-gray-100">
    <%= render "form", material_request: @material_request %>
  </div>
</div>
