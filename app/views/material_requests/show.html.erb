<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="mb-8 flex items-center justify-between border-b border-gray-100 pb-8">
    <div class="flex items-center space-x-6">
      <%= link_to material_requests_path, class: "p-3 rounded-xl bg-white border border-gray-200 text-gray-400 hover:text-indigo-600 hover:border-indigo-100 hover:bg-indigo-50/30 transition-all shadow-sm group" do %>
        <svg class="h-6 w-6 transform group-hover:-translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      <% end %>
      <div>
        <h1 class="text-3xl font-extrabold text-gray-900 leading-tight">要求詳細</h1>
        <div class="flex items-center mt-1 space-x-2">
          <span class="text-xs font-bold text-gray-400 uppercase tracking-widest bg-gray-50 px-2 py-0.5 rounded border">ID: MR-<%= @material_request.id %></span>
          <span class="text-gray-300">•</span>
          <p class="text-xs text-gray-500 font-bold uppercase tracking-wider"><%= @material_request.created_at.strftime("%Y年%m月%d日 %H:%M") %> 作成</p>
        </div>
      </div>
    </div>
    <div class="flex space-x-4">
      <%= link_to edit_material_request_path(@material_request), class: "inline-flex items-center px-6 py-2.5 border border-gray-200 rounded-xl shadow-sm text-sm font-bold text-gray-600 bg-white hover:bg-gray-50 hover:text-indigo-600 transition-all border-b-2 active:translate-y-0.5" do %>
        <svg class="-ml-1 mr-2 h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path d="M13.586 3.586a2 2 0 112.828 2.828l-.707.707-2.828-2.828.707-.707zM11.36 6.036l-6.733 6.733a4 4 0 00-1.044 1.832l-1 4a1 1 0 001.184 1.184l4-1a4 4 0 001.832-1.044l6.733-6.733-2.828-2.828z" />
        </svg>
        編集
      <% end %>
      <%= button_to @material_request, method: :delete, class: "inline-flex items-center px-6 py-2.5 border border-red-100 rounded-xl shadow-sm text-sm font-bold text-red-500 bg-white hover:bg-red-50 transition-all border-b-2 border-red-50 active:translate-y-0.5", data: { confirm: '本当に削除しますか？' } do %>
        削除
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <div class="lg:col-span-2 space-y-10">
      <!-- Header Info Card -->
      <div class="bg-white rounded-3xl shadow-xl shadow-gray-100 border border-gray-100 overflow-hidden">
        <div class="px-8 py-5 bg-gradient-to-r from-gray-50 to-white border-b border-gray-100 flex justify-between items-center">
          <h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest">基本情報 (Header Information)</h2>
          <% status_label, status_color = case @material_request.status
               when "draft" then ["下書き", "bg-gray-100 text-gray-600 border-gray-200"]
               when "pending_approval" then ["承認待ち", "bg-amber-50 text-amber-600 border-amber-100"]
               when "approved" then ["承認済", "bg-emerald-50 text-emerald-600 border-emerald-100"]
               when "returned" then ["差戻し", "bg-rose-50 text-rose-600 border-rose-100"]
               else [@material_request.status.humanize, "bg-gray-100 text-gray-800"]
             end %>
          <span class="px-4 py-1 rounded-full text-[10px] font-black border tracking-widest <%= status_color %> shadow-sm uppercase"><%= status_label %></span>
        </div>
        <div class="p-10">
           <div class="grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-16">
             <div class="group">
               <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5 block group-hover:text-indigo-400 transition-colors">申請者</label>
               <p class="text-sm font-black text-gray-900 bg-gray-50/50 p-3 rounded-xl border border-gray-100"><%= @material_request.applicant.name %></p>
             </div>
             <div class="group">
               <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5 block group-hover:text-indigo-400 transition-colors">依頼部門</label>
               <p class="text-sm font-black text-gray-900 bg-gray-50/50 p-3 rounded-xl border border-gray-100"><%= @material_request.request_org&.name || '（未設定）' %></p>
             </div>
             <div class="group md:col-span-2">
               <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5 block group-hover:text-indigo-400 transition-colors">使用目的</label>
               <p class="text-sm text-gray-700 leading-relaxed font-bold bg-white p-4 rounded-xl border border-gray-100 shadow-sm min-h-[5rem]"><%= @material_request.purpose %></p>
             </div>
             <div class="group md:col-span-2">
               <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5 block group-hover:text-indigo-400 transition-colors">理由・備考</label>
               <p class="text-sm text-gray-500 leading-relaxed font-medium bg-gray-50/30 p-4 rounded-xl border border-gray-100 italic"><%= @material_request.reason.presence || 'なし' %></p>
             </div>
           </div>
        </div>
      </div>

      <!-- Lines Table Card -->
      <div class="bg-white rounded-3xl shadow-xl shadow-gray-100 border border-gray-100 overflow-hidden">
        <div class="px-8 py-5 bg-gradient-to-r from-gray-50 to-white border-b border-gray-100">
          <h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest">要求明細 (Request Lines)</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-100">
            <thead>
              <tr class="bg-white">
                <th class="px-8 py-4 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">品目</th>
                <th class="px-8 py-4 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">数量 / 単位</th>
                <th class="px-8 py-4 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">希望納期</th>
                <th class="px-8 py-4 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">状態</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% @material_request.material_request_lines.each do |line| %>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="px-8 py-6">
                    <div class="text-sm font-black text-gray-900"><%= line.item&.name || line.item_name_free_text %></div>
                    <% if line.item_spec_free_text.present? %>
                      <div class="text-[10px] text-gray-400 mt-1 font-bold"><%= line.item_spec_free_text %></div>
                    <% end %>
                  </td>
                  <td class="px-8 py-6">
                    <div class="flex items-baseline space-x-1">
                      <span class="text-sm font-black text-gray-900"><%= number_with_delimiter(line.order_quantity) %></span>
                      <span class="text-[10px] font-black text-gray-400 uppercase tracking-wider"><%= line.order_unit %></span>
                    </div>
                  </td>
                  <td class="px-8 py-6">
                    <div class="inline-flex items-center px-2 py-1 rounded-md bg-indigo-50 text-indigo-700 text-[10px] font-black tracking-tight">
                      <%= line.required_date&.strftime("%Y/%m/%d") %>
                    </div>
                  </td>
                  <td class="px-8 py-6">
                    <% line_status_label = case line.status
                         when "unprocessed" then "未処理"
                         when "allocated" then "引当済"
                         when "ordered" then "発注済"
                         when "received" then "入荷済"
                         else line.status.humanize
                       end %>
                    <span class="px-2 py-0.5 rounded-lg text-[10px] font-black bg-blue-50 text-blue-700 border border-blue-100 uppercase tracking-widest"><%= line_status_label %></span>
                  </td>
                </tr>
              <% end %>
              <% if @material_request.material_request_lines.empty? %>
                <tr>
                  <td colspan="4" class="px-8 py-12 text-center text-gray-400 bg-gray-50/30">
                    <p class="text-xs font-bold tracking-widest italic uppercase">要求明細がありません</p>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Sidebar Activity -->
    <div class="space-y-8">
      <div class="bg-gray-900 rounded-3xl shadow-2xl shadow-indigo-100 p-8 text-white overflow-hidden relative border-4 border-gray-800">
        <h3 class="text-[10px] font-black uppercase tracking-widest text-indigo-400 mb-10 border-b border-gray-800 pb-4">承認タイムライン</h3>
        <div class="space-y-10 relative">
          <!-- Timeline line -->
          <div class="absolute left-3 top-2 bottom-2 w-0.5 bg-gray-800"></div>
          
          <% @material_request.approval_activities.each do |activity| %>
            <div class="flex items-start relative group">
              <div class="h-6 w-6 rounded-full bg-indigo-500 border-4 border-gray-900 z-10 flex-shrink-0 group-hover:scale-125 transition-transform shadow-[0_0_15px_rgba(79,70,229,0.4)]"></div>
              <div class="ml-6">
                <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest"><%= activity.step_name %></p>
                <p class="text-sm font-black mt-1.5"><%= activity.action.humanize %></p>
                <div class="flex items-center mt-2 space-x-2">
                  <p class="text-[10px] font-bold text-gray-500 uppercase tracking-tight"><%= activity.approver.name %></p>
                  <span class="text-gray-700 text-xs">•</span>
                  <p class="text-[10px] font-bold text-gray-500 uppercase tracking-tight"><%= time_ago_in_words(activity.created_at) %>前</p>
                </div>
                <% if activity.comment.present? %>
                  <div class="mt-4 bg-gray-800/50 rounded-xl p-4 text-xs text-gray-400 font-medium italic border-l-4 border-indigo-500 shadow-inner">
                    "<%= activity.comment %>"
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if @material_request.approval_activities.empty? %>
            <div class="flex flex-col items-center justify-center py-16 opacity-30 grayscale items-center text-center">
              <svg class="h-10 w-10 text-gray-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="text-[10px] font-black tracking-[0.2em] text-gray-500 italic">承認履歴がありません</p>
            </div>
          <% end %>
        </div>
      </div>

      <% if @material_request.draft? || @material_request.returned? %>
        <div class="bg-indigo-50/50 rounded-3xl p-8 border border-indigo-100 flex flex-col items-center text-center">
          <div class="h-12 w-12 rounded-2xl bg-indigo-600 flex items-center justify-center text-white shadow-lg mb-4">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h4 class="text-sm font-black text-indigo-900 tracking-tight">次のステップ</h4>
          <p class="text-xs text-indigo-600 font-bold mt-2 leading-relaxed italic">この要求を下書きから承認待ちへ進めることができます。</p>
          <%= button_to "申請を提出する", submit_material_request_path(@material_request), method: :patch, class: "mt-6 w-full py-3 bg-white border border-indigo-200 text-indigo-700 text-xs font-black rounded-xl shadow-sm hover:shadow-md hover:bg-indigo-50 transition-all active:scale-95 cursor-pointer" %>
        </div>
      <% elsif @material_request.pending_approval? %>
        <div class="bg-amber-50/50 rounded-3xl p-8 border border-amber-100 flex flex-col items-center text-center">
          <div class="h-12 w-12 rounded-2xl bg-amber-500 flex items-center justify-center text-white shadow-lg mb-4">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h4 class="text-sm font-black text-amber-900 tracking-tight">承認待ち</h4>
          <p class="text-xs text-amber-600 font-bold mt-2 leading-relaxed italic">この要求を承認するか、差し戻すことができます。</p>
          <div class="mt-6 w-full grid grid-cols-2 gap-4">
            <%= button_to "承認する", approve_material_request_path(@material_request), method: :patch, class: "py-3 bg-emerald-600 text-white text-xs font-black rounded-xl shadow-md hover:bg-emerald-700 transition-all active:scale-95 cursor-pointer shadow-emerald-100" %>
            <%= button_to "差し戻す", reject_material_request_path(@material_request), method: :patch, class: "py-3 bg-white border border-rose-200 text-rose-600 text-xs font-black rounded-xl shadow-sm hover:bg-rose-50 transition-all active:scale-95 cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
