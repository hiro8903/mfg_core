<%# [意図] 状態（Status）や権限を、色とラベルで直感的に識別できるようにするため。 %>
<%# [意味] 指定された色（color）と文字（label）で、製造現場のドメインに基づいた共通のデザインルールに従った丸いタグ(Badge)を生成する。 %>
<%
  # 製造・物流現場やシステム全体で、パッと見て迷わないような「明確な違い」がある色を厳選
  color_classes = case color&.to_sym
                  when :blue    then "bg-blue-100 text-blue-700 border-blue-200"       # [予定・未着手] 作業前(未着手)、計画中、新規受付、ただの情報ラベル
                  when :green   then "bg-emerald-100 text-emerald-700 border-emerald-200" # [進行・正常] 順調に進行している作業、稼働中、納期に余裕あり
                  when :yellow  then "bg-yellow-100 text-yellow-700 border-yellow-200" # [注意・遅延] 異常はあるが進行している作業、手直し中、納期間近
                  when :red     then "bg-red-100 text-red-700 border-red-200"          # [異常・停止] 異常による停止、スクラップ(廃棄)、納期遅延、エラー
                  when :gray    then "bg-gray-200 text-gray-700 border-gray-300"       # [完了・無効] 出荷済み、アーカイブ

                  # 以下は業務ステータスとは別に、「システム側の特権」など絶対に混同させたくない場合のみ使用
                  when :purple  then "bg-purple-100 text-purple-700 border-purple-200" # [特殊・管理] 管理者設定、システムマスタの操作など
                  else "bg-gray-100 text-gray-700 border-gray-200"
                  end
%>

<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold border <%= color_classes %> <%= local_assigns[:class] %>">
  <%= label %>
</span>
