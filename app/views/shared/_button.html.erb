<%# [意図] ボタンのデザインと役割を一元管理し、アプリケーション全体で操作の重みを統一するため。 %>
<%# [意味] 引数（color, label, path等）に応じて、共通のスタイルを適用したHTMLタグを生成する。 %>

<%
  # 1. アクションの種類に応じた色切り替え
  color = local_assigns[:color] || :blue
  colors = case color.to_sym
    when :blue      then "bg-blue-600 text-white hover:bg-blue-700 shadow-blue-100"       # [決定・実行] 保存、新規作成、検索実行、承認、出荷確定など前に進むメイン操作
    when :green     then "bg-emerald-600 text-white hover:bg-emerald-700"                # [編集・変更] 既存データを修正するため、編集画面へ移動する操作
    when :white     then "bg-white text-gray-700 border border-gray-300 hover:bg-gray-50" # [取消・戻る] 前の画面に戻る、キャンセル、詳細を閉じるなど、何もしない操作
    when :red       then "bg-red-600 text-white hover:bg-red-700"                       # [危険・削除] 取り返しのつかない破壊的操作（削除、工程の致命的な停止）
    when :yellow    then "bg-yellow-500 text-white hover:bg-yellow-600"                  # [注意・中断] 処理を中断するような特別な操作（手直し指示、差戻し、保留）
    else "bg-gray-600 text-white hover:bg-gray-700"
  end



  # 2. 基本クラス（クリック時の押し込み感 active:scale-95 を追加）
  base_classes = "inline-flex items-center px-4 py-2 rounded-md font-medium text-sm no-underline transition-all shadow-sm cursor-pointer whitespace-nowrap flex-shrink-0 active:scale-95"

  # 3. 呼び出し側からの追加クラスがあれば結合
  full_classes = "#{base_classes} #{colors} #{local_assigns[:class]}"
%>

<% if local_assigns[:form].present? %>
  <%# A. フォーム送信ボタンの場合 %>
  <%= local_assigns[:form].submit label, class: full_classes %>

<% elsif local_assigns[:method].present? %>
  <%# B. DELETE や PATCH などの特定メソッドが必要な場合（button_to） %>
  <%= button_to label, path,
        method: method,
        form_class: "inline",
        data: { turbo_confirm: local_assigns[:confirm] },
        class: full_classes %>

<% else %>
  <%# C. 通常のリンクボタン（link_to） %>
  <%= link_to label, path, class: full_classes %>
<% end %>
