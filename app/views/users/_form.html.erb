<div class="bg-white rounded-lg border border-gray-200 overflow-hidden shadow-sm">
  <div class="p-8">
    <%= form_with model: user, local: true, class: "flex flex-col gap-6" do |f| %>
      
      <%# エラー表示エリア %>
      <% if user.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4 text-red-800">
          <h2 class="text-base font-semibold mb-2"><%= user.errors.count %>件のエラーがあります:</h2>
          <ul class="m-0 pl-5 text-sm list-disc">
            <% user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "氏名 (Full Name)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.text_field :name, placeholder: "例: 山田 太郎", class: "w-full px-3 py-2.5 border border-gray-300 rounded-md text-base focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :user_code, "業務 ID (Business ID)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.text_field :user_code, placeholder: "例: M101, U202", class: "w-full px-3 py-2.5 border border-gray-300 rounded-md font-mono text-base focus:ring-blue-500 focus:border-blue-500" %>
        <p class="mt-1 text-gray-500 text-xs">半角英数字で入力してください。自動的に大文字で保存されます。</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :password, "パスワード (Password)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.password_field :password, placeholder: user.new_record? ? "8文字以上推奨" : "変更しない場合は空欄", class: "w-full px-3 py-2.5 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500 text-base" %>
        </div>
        <div>
          <%= f.label :password_confirmation, "パスワード確認 (Confirm)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.password_field :password_confirmation, placeholder: "確認のため再入力", class: "w-full px-3 py-2.5 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500 text-base" %>
        </div>
      </div>

      <div class="pt-4 mt-4 border-t border-gray-100 text-base">
        <%= f.submit user.new_record? ? "ユーザーを登録する (Register)" : "情報を更新する (Update)", class: "w-full bg-blue-600 text-white p-3 rounded-md font-semibold cursor-pointer text-base hover:bg-blue-700 shadow-sm" %>
      </div>

    <% end %>
  </div>
</div>
