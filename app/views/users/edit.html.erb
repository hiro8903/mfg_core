<%# [意図] ユーザー情報編集画面のヘッダーを共通コンポーネントで統一し、ブランドイメージを維持するため。 %>
<%# [意味] タイトル、サブテキスト、および「表示に戻る」ボタンを配置したヘッダー領域。 %>
<%= render "shared/page_header",
    title: "ユーザー情報更新 (Edit User)",
    subtitle: "登録されているユーザー情報を変更します",
    actions: capture { %>
      <%= link_to "表示に戻る (Show)", @user, class: "bg-white text-gray-700 px-4 py-2 border border-gray-300 rounded-md no-underline font-medium text-sm hover:bg-gray-50 shadow-sm" %>
<% } %>

  <%= render "form", user: @user %>
</div>
