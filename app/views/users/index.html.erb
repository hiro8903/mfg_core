<%# [意図] システムの利用者である全従業員の情報を一元管理し、在職・退職のステータスを素早く切り替えるため。 %>
<%# [意味] ユーザー一覧をタブ形式で表示し、検索や新規登録の起点となるメイン管理画面。 %>

<%# [意図] 共有見出しコンポーネントを使用し、プロジェクト全体で「管理画面の顔」を統一するため。 %>
<%# [意味] 画面タイトル、サブタイトル、および「現職／退職」のタブ表示を行うトップセクション。 %>
<%= render "shared/page_header", 
    title: "ユーザー管理 (User Management)",
    subtitle: "システムを利用する全ユーザー情報の閲覧、編集および在職・退職の状態管理を行います。",
    actions: capture { %>
      <div class="flex gap-6 items-center">
        <%# タブナビゲーション：表示条件に合わせたボーダーと色の切り替えロジックを継承 %>
        <div class="flex gap-4 border-b-2 border-gray-200">
          <%= link_to "現職 (Active)", users_path, 
              class: "px-4 py-2 no-underline font-semibold border-b-2 #{params[:discarded] != 'true' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500'}" %>
          <%= link_to "退職済み (Retired)", users_path(discarded: true), 
              class: "px-4 py-2 no-underline font-semibold border-b-2 #{params[:discarded] == 'true' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500'}" %>
        </div>
        
        <%# 新規登録ボタン %>
        <%= render "shared/button", label: "新規登録 (New)", path: new_user_path, color: :blue %>
      </div>
    <% } %>

<%# 共通カード部品の適用（テーブル表示のため内部余白はなし） %>
<%= render "shared/card", body_class: "overflow-x-auto" do %>
  <table class="w-full border-collapse text-left">
    <%# ヘッダー：背景グレー50、下線 %>　
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="px-4 py-3 font-semibold text-gray-700">業務 ID</th>
        <th class="px-4 py-3 font-semibold text-gray-700">氏名 (Name)</th>
        <th class="px-4 py-3 font-semibold text-gray-700">主な所属組織 (Org Unit)</th>
        <th class="px-4 py-3 font-semibold text-gray-700">拠点 (Facility)</th>
        <th class="px-4 py-3 font-semibold text-gray-700 text-center w-60 whitespace-nowrap">操作 (Action)</th>
      </tr>
    </thead>
    <%# 行間にグレー100の区切り線 %>
    <tbody class="divide-y divide-gray-100">
      <% @users.each do |user| %>
        <tr class="border-b border-gray-50">
          <td class="p-4 font-mono text-gray-900"><%= user.user_code %></td>
          <td class="p-4 text-gray-900 font-medium"><%= user.name %></td>
          <td class="p-4 text-gray-600">
            <%# 元の所属判定ロジックをそのまま継承 %>
            <%= user.assignments.find_by("start_date <= ? AND (end_date IS NULL OR end_date >= ?)", Date.today, Date.today)&.org_unit&.name || "-" %>
          </td>
          <td class="p-4 text-gray-600">
            <%# 元の拠点取得ロジックをそのまま継承 %>
            <%= user.facilities.map(&:name).join(", ").presence || "-" %>
          </td>
          <td class="p-4 text-center whitespace-nowrap">
            <div class="flex gap-2 justify-center">
              <%= render "shared/button", label: "詳細", path: user_path(user), color: :white, class: "text-xs" %>
              <%= render "shared/button", label: "編集", path: edit_user_path(user), color: :green, class: "text-xs" %>

              <%# ステータスに応じたボタンの色の切り替え %>
              <% if user.discarded_at.present? %>
                <%= render "shared/button", label: "復職", path: undiscard_user_path(user), 
                      color: :blue, method: :patch, confirm: "復職処理の訂正（現職への復帰）を行いますか？", class: "text-xs" %>
              <% else %>
                <%= render "shared/button", label: "退職", path: user_path(user), 
                      color: :red, method: :delete, confirm: "本当に退職処理（無効化）してもよろしいですか？", class: "text-xs" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
