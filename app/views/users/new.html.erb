<%# [意図] 新規ユーザー登録画面のヘッダーを共通コンポーネントで統一し、ブランドイメージを維持するため。 %>
<%# [意味] タイトル、サブテキスト、および「キャンセル」ボタンを配置したヘッダー領域。 %>
<%= render "shared/page_header",
    title: "新規ユーザー登録 (New User)",
    subtitle: "システムを利用する新しいメンバーを追加します",
    actions: capture { %>
      <%= link_to "キャンセル (Back)", users_path, class: "bg-white text-gray-700 px-4 py-2 border border-gray-300 rounded-md no-underline font-medium text-sm hover:bg-gray-50 shadow-sm" %>
<% } %>

  <%= render "form", user: @user %>
</div>
