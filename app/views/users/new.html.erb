<div style="max-width: 42rem; margin: 0 auto;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
      <h1 style="margin: 0; font-size: 1.875rem; font-weight: 700;">新規ユーザー登録 (New User)</h1>
      <p style="margin: 0.25rem 0 0; color: #6b7280; font-size: 0.875rem;">システムを利用する新しいメンバーを追加します</p>
    </div>
    <%= link_to "キャンセル (Back)", users_path, style: "background: white; color: #374151; padding: 0.5rem 1rem; border: 1px solid #d1d5db; border-radius: 0.375rem; text-decoration: none; font-weight: 500; font-size: 0.875rem;" %>
  </div>

  <%= render "form", user: @user %>
</div>
