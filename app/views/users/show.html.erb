<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
  <div>
    <h1 style="margin: 0; font-size: 1.875rem; font-weight: 700;">ユーザー詳細 (User Detail)</h1>
    <p style="margin: 0.25rem 0 0; color: #6b7280; font-size: 0.875rem;">ユーザーの基本情報と権限の確認</p>
  </div>
  <div style="display: flex; gap: 0.75rem;">
    <%= link_to "一覧に戻る (Back)", users_path, style: "background: white; color: #374151; padding: 0.5rem 1rem; border: 1px solid #d1d5db; border-radius: 0.375rem; text-decoration: none; font-weight: 500;" %>
    <%= link_to "編集する (Edit)", edit_user_path(@user), style: "background: #2563eb; color: white; padding: 0.5rem 1rem; border-radius: 0.375rem; text-decoration: none; font-weight: 500;" %>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem;">
  <!-- 基本情報カード -->
  <div style="background: white; border-radius: 0.5rem; border: 1px solid #e5e7eb; overflow: hidden; box-shadow: 0 1px 2px rgba(0,0,0,0.05); height: fit-content;">
    <div style="padding: 1rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; font-weight: 600; color: #374151;">
      基本情報 (Basic Info)
    </div>
    <div style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
      <div>
        <label style="display: block; font-size: 0.75rem; color: #6b7280; text-transform: uppercase;">業務 ID</label>
        <span style="font-size: 1.125rem; font-family: monospace; font-weight: 600; color: #111827;"><%= @user.user_code %></span>
      </div>
      <div>
        <label style="display: block; font-size: 0.75rem; color: #6b7280; text-transform: uppercase;">氏名</label>
        <span style="font-size: 1.125rem; font-weight: 500; color: #111827;"><%= @user.name %></span>
      </div>
    </div>
  </div>

  <!-- 配属と権限の詳細 -->
  <div style="display: flex; flex-direction: column; gap: 1.5rem;">
    <!-- 配属履歴カード -->
    <div style="background: white; border-radius: 0.5rem; border: 1px solid #e5e7eb; overflow: hidden; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
      <div style="padding: 1rem; background: #f9fafb; border-bottom: 1px solid #e5e7eb; font-weight: 600; color: #374151;">
        配属履歴と保持権限 (Assignments & Permissions)
      </div>
      <div style="padding: 0;">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
          <thead style="background: #f9fafb; border-bottom: 1px solid #e5e7eb;">
            <tr>
              <th style="padding: 0.75rem 1rem; font-size: 0.75rem; color: #6b7280; font-weight: 600;">期間 (Period)</th>
              <th style="padding: 0.75rem 1rem; font-size: 0.75rem; color: #6b7280; font-weight: 600;">所属組織 (Org Unit)</th>
              <th style="padding: 0.75rem 1rem; font-size: 0.75rem; color: #6b7280; font-weight: 600;">取得される権限 (Permissions)</th>
            </tr>
          </thead>
          <tbody>
            <% @assignments.each do |assignment| %>
              <tr style="border-bottom: 1px solid #f3f4f6;">
                <td style="padding: 0.75rem 1rem; font-size: 0.875rem;">
                  <%= assignment.start_date %> 〜 <%= assignment.end_date || "現在" %>
                </td>
                <td style="padding: 0.75rem 1rem; font-size: 0.875rem; color: #111827; font-weight: 500;">
                  <%= assignment.org_unit.name %>
                </td>
                <td style="padding: 0.75rem 1rem; font-size: 0.875rem;">
                  <% if assignment.org_unit.org_unit_permissions.any? %>
                    <div style="display: flex; flex-wrap: wrap; gap: 0.25rem;">
                      <% assignment.org_unit.org_unit_permissions.each do |perm| %>
                        <span style="background: #ecfdf5; color: #065f46; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; border: 1px solid #a7f3d0;">
                          <%= perm.permission_name %>
                        </span>
                      <% end %>
                    </div>
                  <% else %>
                    <span style="color: #9ca3af; font-size: 0.75rem;">権限定義なし</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
