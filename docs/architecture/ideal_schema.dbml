Project Mfg_Core_Ideal_Architecture {
  database_type: 'PostgreSQL'
  Note: '製造業中核アプリケーション：将来の理想的なデータ構造'
}

// -------------------- I. ユーザー・組織管理 (HR) --------------------

Table users {
  id integer [primary key]
  user_code varchar [unique, not null, note: 'ログイン用ID (業務コード)']
  name varchar [not null, note: '氏名（フルネーム）']
  password_digest varchar [not null, note: '暗号化されたパスワード']
  created_at timestamp
  updated_at timestamp

  Note: '本質的な個人情報を管理するテーブル'
}

Table locations {
  id integer [primary key]
  code varchar [unique, not null, note: '拠点コード (例: L001)']
  name varchar [not null, note: '拠点名 (例: 東京工場)']
  address text [note: '住所']

  Note: '物理的な場所（勤務地）を管理'
}

Table departments {
  id integer [primary key]
  parent_id integer [ref: > departments.id, note: '親部門 (階層構造用)']
  code varchar [unique, not null, note: '部門コード (例: D100)']
  name varchar [not null, note: '部門名 (例: 製造部)']

  Note: '組織上の論理的な部門を管理'
}

Table assignments {
  id integer [primary key]
  user_id integer [not null, ref: > users.id]
  location_id integer [not null, ref: > locations.id]
  department_id integer [not null, ref: > departments.id]
  job_title varchar [note: '仕事上の肩書き (例: 工場長)']
  role integer [default: 0, note: 'システム上の権限種別 (Enum)']
  start_date date [not null, note: '発令日']
  end_date date [note: '失効日 (NULLなら現行)']

  Note: '誰が・どこで・何の役割を「いつからいつまで」担っているかの履歴'
}

// -------------------- II. 認証・ログイン --------------------

Table sessions {
  id integer [primary key]
  user_id integer [not null, ref: > users.id]
  ip_address varchar
  user_agent varchar
  created_at timestamp
  updated_at timestamp

  Note: 'Rails 8 Native Authenticationのためのセッション管理'
}
