Project Mfg_Core_Ideal_Architecture {
  database_type: 'PostgreSQL'
  Note: '製造業中核アプリケーション：将来の理想的なデータ構造 (Dynamic Permissions & HR Support)'
}

// -------------------- I. ユーザー・組織・人事マスタ (HR) --------------------

Table users {
  id integer [primary key]
  user_code varchar [unique, not null, note: 'ログイン用ID (業務コード)']
  name varchar [not null, note: '氏名（フルネーム）']
  password_digest varchar [not null, note: '暗号化されたパスワード']
  discarded_at timestamp [note: '退職・無効化日 (NULLなら有効)']
  created_at timestamp
  updated_at timestamp

  Note: '本質的な個人情報を管理。認証の主体。'
}

Table facilities {
  id integer [primary key]
  code varchar [unique, not null, note: '拠点・サイトコード (例: L001)']
  name varchar [not null, note: '拠点名 (例: 東京工場)']
  address text [note: '住所']
  discarded_at timestamp [note: '拠点廃止日時 (NULLなら有効)']

  Note: '物理的な拠点（オフィス、工場等）を管理。人事上の配属先。'
}

Table org_units {
  id integer [primary key]
  parent_id integer [ref: > org_units.id, note: '親組織 (階層構造用)']
  code varchar [unique, not null, note: '組織コード (例: D100)']
  name varchar [not null, note: '組織名 (例: 製造部, 製造1課, 安全委員会)']
  org_type integer [default: 0, note: '組織種別 (0:部署, 1:PJ, 2:委員会)']
  discarded_at timestamp [note: '組織廃止日時 (NULLなら有効)']

  Note: '論理的な組織単位。ここに権限が紐付く。'
}

Table org_unit_permissions {
  id integer [primary key]
  org_unit_id integer [not null, ref: > org_units.id, note: '組織ID']
  permission integer [not null, note: '権限種別 (system_admin, manage_hr, view_inventory等)']
  created_at timestamp
  updated_at timestamp

  Note: '【ADR 003】組織に権限を紐付け、配属によってユーザーへ継承させる'
}

Table assignments {
  id integer [primary key]
  user_id integer [not null, ref: > users.id]
  facility_id integer [not null, ref: > facilities.id]
  org_unit_id integer [not null, ref: > org_units.id]
  job_title varchar [note: '仕事上の肩書き (人間界の役割)']
  role integer [default: 0, note: '配属役職区分 (0:作業員, 1:管理者等)']
  is_primary boolean [default: true, note: '主属フラグ (兼務の場合のメイン所属)']
  start_date date [not null, note: '適用開始日']
  end_date date [note: '適用終了日 (NULLなら現行)']

  Note: '【ADR 002】誰が・どこで・何の役割を「いつからいつまで」担っているかの履歴'
}

// -------------------- II. 在庫・場所管理 (Inventory & Storage) --------------------

Table locations {
  id integer [primary key]
  facility_id integer [not null, ref: > facilities.id, note: '所属拠点']
  code varchar [unique, not null, note: '場所コード (例: W001-S01-A)']
  name varchar [not null, note: '場所名 (例: 倉庫A-棚B1)']
  discarded_at timestamp [note: '場所廃止日時']

  Note: '物理的置き場所（棚・部屋等）'
}

Table inventories {
  id integer [primary key]
  item_id integer [note: '品番マスタ参照用（将来拡張）']
  org_unit_id integer [not null, ref: > org_units.id, note: '論理的所有組織 (必須・会計単位)']
  location_id integer [ref: > locations.id, note: '物理的場所 (任意・棚卸単位)']
  quantity decimal [not null, default: 0, note: '在庫数量']

  Note: '論理的所有と物理場所を両立させるハイブリッド設計'
}

// -------------------- III. 認証・ログイン --------------------

Table sessions {
  id integer [primary key]
  user_id integer [not null, ref: > users.id]
  ip_address varchar
  user_agent varchar
  created_at timestamp
  updated_at timestamp

  Note: 'Rails 8 Native Authentication'
}
